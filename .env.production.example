# AWS Deployment Environment Variables Template
# Copy this to .env.production on your EC2 instance

APP_NAME="Bozor"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com
APP_IMAGE=fuzalov/bozor-app:latest
APP_CONTAINER_NAME=bozor-app
CADDY_CONTAINER_NAME=bozor-caddy
POSTGRES_CONTAINER_NAME=bozor-postgres
REDIS_CONTAINER_NAME=bozor-redis
PUBLIC_NETWORK_NAME=bozor-public
APP_UPSTREAM=app:80
STAGING_APP_DOMAIN=staging.yourdomain.com
STAGING_APP_UPSTREAM=bozor-staging-app:80
TRUSTED_PROXIES=*

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Database Configuration (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bozor_prod
DB_USERNAME=bozor_user
DB_PASSWORD=your_secure_password_here

# Cache & Queue (Redis)
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# S3 Configuration
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_URL=
AWS_VISIBILITY=public

# Mail Configuration
MAIL_MAILER=ses
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=your_ses_username
MAIL_PASSWORD=your_ses_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Optional: Seed database on first deployment
SEED_DATABASE=true
