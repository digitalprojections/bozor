# Staging Deployment Environment Variables Template
# Copy this to .env.staging on your staging EC2 instance

APP_NAME="Bozor Staging"
APP_ENV=staging
APP_DEBUG=false
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
APP_URL=https://staging.bazaarjapan.link
APP_DOMAIN=staging.bazaarjapan.link
APP_IMAGE=fuzalov/bozor-app:staging
APP_CONTAINER_NAME=bozor-staging-app
CADDY_CONTAINER_NAME=bozor-staging-caddy
POSTGRES_CONTAINER_NAME=bozor-staging-postgres
REDIS_CONTAINER_NAME=bozor-staging-redis
PUBLIC_NETWORK_NAME=bozor-public
TRUSTED_PROXIES=*

GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret
GOOGLE_REDIRECT_URI=https://staging.bazaarjapan.link/auth/google/callback

# Database Configuration (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bozor_staging
DB_USERNAME=bozor_staging
DB_PASSWORD=your_secure_staging_password_here

# Cache & Queue (Redis)
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# S3 Configuration
# Use a separate staging bucket so tests never mutate production uploads.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=your_staging_aws_access_key
AWS_SECRET_ACCESS_KEY=your_staging_aws_secret_key
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=bozor-staging-uploads
AWS_URL=https://bozor-staging-uploads.s3.ap-northeast-1.amazonaws.com
AWS_VISIBILITY=public

# Mail Configuration
# Keep staging on log/sandbox mail until you explicitly need end-to-end SES tests.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=staging-noreply@bazaarjapan.link
MAIL_FROM_NAME="${APP_NAME}"
